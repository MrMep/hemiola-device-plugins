  "help": [
    {
      "title": "Akai LPD8 \u2013 Overview",
      "icon": "tune",
      "entries": [
        {
          "type": "para",
          "text": "The Akai LPD8 is a USB MIDI pad controller with 8 velocity-sensitive pads and 8 assignable knobs. It stores 4 internal programs, each with independent MIDI channel, pad assignments, and knob mappings."
        },
        {
          "type": "note",
          "text": "The LPD8 uses bulk SysEx transfers only. Changes are NOT sent in real time. Use the Load buttons to read a program from the device, edit the settings, then press Write to save them back."
        }
      ]
    },
    {
      "title": "Controlling Hemiola",
      "icon": "sports_esports",
      "entries": [
        {
          "type": "para",
          "text": "The LPD8 can control Hemiola's synth engine in real time. Pads toggle modules on/off (e.g. LPF, LFO, Reverb, Chorus, Delay), while knobs adjust continuous parameters (e.g. Filter Cutoff, ADSR, FX sends)."
        },
        {
          "type": "note",
          "text": "Pads should be in Momentary mode (Toggle off) when used for Hemiola module toggles: each press sends a note-on that Hemiola interprets as a toggle command."
        },
        {
          "type": "subtitle",
          "text": "Factory Presets"
        },
        {
          "type": "note",
          "text": "Preset table format: K1..K8 = knob CCs, P1..P8 = pad Note numbers. Channel shown below is the built-in mapping channel (11 user-visible, MIDI byte value 10)."
        },
        {
          "type": "subtitle",
          "text": "Minimoog Perf"
        },
        {
          "type": "item",
          "text": "Channel: 11 | K1..K8: 1,79,98,67,68,69,64,65 | P1..P8: 49,77,23,72,116,110,112,121"
        },
        {
          "type": "item",
          "text": "Use case: classic monosynth performance with filter, envelope, and modulation controls."
        },
        {
          "type": "subtitle",
          "text": "Filter & Env"
        },
        {
          "type": "item",
          "text": "Channel: 11 | K1..K8: 78,82,96,97,67,68,75,76 | P1..P8: 49,77,72,119,112,109,113,16"
        },
        {
          "type": "item",
          "text": "Use case: deep filter sculpting and ADSR envelope shaping."
        },
        {
          "type": "subtitle",
          "text": "Osc & Duty"
        },
        {
          "type": "item",
          "text": "Channel: 11 | K1..K8: 101,102,103,58,59,60,5,105 | P1..P8: 49,23,24,116,60,64,67,72"
        },
        {
          "type": "item",
          "text": "Use case: oscillator mixing, waveform duty cycle adjustment, and tone shaping."
        },
        {
          "type": "subtitle",
          "text": "Live FX & Mix"
        },
        {
          "type": "item",
          "text": "Channel: 11 | K1..K8: 17,50,81,88,95,90,84,93 | P1..P8: 16,49,80,87,92,107,105,106"
        },
        {
          "type": "item",
          "text": "Use case: live effects sends, delay/reverb tweaks, and master mix balancing."
        }
      ]
    },
    {
      "title": "Tab: Setup",
      "icon": "settings",
      "entries": [
        {
          "type": "subtitle",
          "text": "Load Program 1\u20134"
        },
        {
          "type": "para",
          "text": "Reads the selected program slot from the device and populates all pad and knob parameters."
        },
        {
          "type": "subtitle",
          "text": "Write to Program Slot"
        },
        {
          "type": "para",
          "text": "Selects which of the 4 internal program slots will be overwritten when you press the Write button."
        },
        {
          "type": "note",
          "text": "Hint: after selecting the target slot, tap Write To Device at the bottom of the Setup tab to actually send the SysEx write message."
        },
        {
          "type": "subtitle",
          "text": "MIDI Channel"
        },
        {
          "type": "para",
          "text": "Sets the MIDI channel for the current program (1\u201316). All pad notes, CC messages, and program changes will be sent on this channel."
        }
      ]
    },
    {
      "title": "Tab: Pads",
      "icon": "grid_view",
      "entries": [
        {
          "type": "para",
          "text": "Each pad has a Note number (sent on pad hit), a CC number, a Program Change number, and a Toggle/Momentary mode. In Momentary mode the pad sends note-on on press and note-off on release. In Toggle mode, one press sends note-on and the next press sends note-off."
        },
        {
          "type": "note",
          "text": "For controlling Hemiola modules, use Momentary mode and set the Note to the Hemiola parameter toggle number (e.g. 77 for LPF, 72 for LFO, 80 for Reverb). See the factory presets for ready-made mappings."
        }
      ]
    },
    {
      "title": "Tab: Knobs",
      "icon": "tune",
      "entries": [
        {
          "type": "para",
          "text": "Each knob is assigned a CC number and a value range (Min/Max). The physical knob sweep is mapped to the configured CC range."
        },
        {
          "type": "note",
          "text": "Set the CC to a Hemiola parameter CC (e.g. 1 for Filter Cutoff, 67\u201370 for ADSR, 81 for Reverb Send) and use Min=0, Max=127 for full range."
        }
      ]
    }
  ]
}